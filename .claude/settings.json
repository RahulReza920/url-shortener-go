{
  "permissions": {
    "allow": [
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(go run *)",
      "Bash(gofmt *)",
      "Bash(go mod tidy)",
      "Bash(go mod download)",
      "Bash(redis-cli *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // \"\"'); case \"$f\" in *.go) gofmt -w \"$f\" && cd /Users/rahulreza/Downloads/url-shortener && go vet ./... 2>&1 ;; esac",
            "statusMessage": "gofmt + go vet"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); cmd=$(echo \"$input\" | jq -r '.tool_input.command // \"\"' | xargs); if echo \"$cmd\" | grep -qE '^git commit'; then cd /Users/rahulreza/Downloads/url-shortener && go test ./... 2>&1 || exit 1; fi",
            "statusMessage": "pre-commit: go test ./..."
          }
        ]
      }
    ]
  }
}
